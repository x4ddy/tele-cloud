# TeleCloud frontend configuration (Vite).
# Copy to `.env.local` for local dev, or set these in the Vercel dashboard
# (Project → Settings → Environment Variables) for production.
#
# Only variables prefixed with VITE_ are exposed to the browser. All values here
# are PUBLIC by design (the API base is a URL; the Supabase anon key is meant to
# be shipped to browsers — it is gated by Row Level Security, not secrecy).

# Base URL of the backend API (the Render service).
# - Production: set to your Render URL, e.g. https://telecloud-api.onrender.com
# - Local dev: leave EMPTY to use the Vite dev proxy (same-origin, no CORS).
VITE_API_BASE=

# Supabase project URL and anon key — used ONLY for client-side token refresh
# (renewing the access token before it expires / on a 401). From the Supabase
# dashboard: Project Settings → API. These MUST match the backend's Supabase project.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-public-key

# (dev only, optional) Where the Vite proxy forwards API calls when VITE_API_BASE
# is empty. Defaults to http://127.0.0.1:8000.
# DEV_API_TARGET=http://127.0.0.1:8000
