{
  "openapi": "3.1.0",
  "info": {
    "title": "TeleCloud",
    "description": "A cloud storage system that uses Telegram's Bot API as the storage backend.",
    "version": "1.0.0"
  },
  "paths": {
    "/auth/signup": {
      "post": {
        "tags": [
          "auth"
        ],
        "summary": "Signup",
        "description": "Create an account (Supabase) and its profile shell, return a session.",
        "operationId": "signup_auth_signup_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SignupRequest"
