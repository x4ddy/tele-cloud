              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        },
        "security": [
          {
            "HTTPBearer": []
          }
        ]
      }
    },
    "/users/me": {
      "get": {
        "tags": [
          "users"
        ],
        "summary": "Read Profile",
        "description": "Return the caller's profile (read fresh via the repo).",
        "operationId": "read_profile_users_me_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProfileResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "HTTPBearer": []
          }
        ]
      }
    },
    "/users/verify": {
      "post": {
        "tags": [
          "users"
        ],
        "summary": "Request Verification",
        "description": "Start email verification: issue a token and send the link.\n\nReturns ``202 Accepted`` \u2014 the email send is fire-and-forget from the client's\nview. No-op (still 202) if the caller is already verified. The caller's JWT is\nneeded to persist the token on their own profile row under RLS.",
        "operationId": "request_verification_users_verify_post",
        "responses": {
          "202": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        },
        "security": [
          {
            "HTTPBearer": []
          }
        ]
      }
    },
    "/users/verify/confirm": {
      "post": {
        "tags": [
          "users"
        ],
        "summary": "Confirm Verification",
        "description": "Redeem a verification token; return the now-verified profile.\n\nUnauthenticated by design \u2014 the unguessable token is the capability. An\ninvalid/expired token raises ``validation_error`` (422).",
        "operationId": "confirm_verification_users_verify_confirm_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/VerificationConfirmRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProfileResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
