        "summary": "Revoke Share",
        "description": "Revoke one of the caller's share links (soft: ``revoked=true``).\n\nReturns the updated row; revoking an already-revoked link is idempotent.\nSubsequent public downloads of the token are rejected with ``share_revoked``.",
        "operationId": "revoke_share_shares__share_id__revoke_post",
        "security": [
          {
            "HTTPBearer": []
          }
        ],
        "parameters": [
          {
            "name": "share_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid",
