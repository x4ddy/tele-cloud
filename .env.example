# TeleCloud — environment configuration template
#
# Copy this file to `.env` (read automatically in local dev) and fill in real
# values. In production (Fly.io) set these as real environment variables instead.
# Every variable here is REQUIRED unless explicitly marked optional.
# NEVER commit a filled-in `.env` — only this `.env.example` (no real secrets).
#
# All of these are read through telecloud/config ONLY. No other module reads the
# environment directly (SPEC.md §5.2).

# --- Telegram (round-robin bot pool + storage channels) — SPEC §6.8 ---------
# Comma-separated. At least one of each is required.
# Bot tokens come from @BotFather. Channel ids are the private channels the bots
# post chunks to (negative bigints, typically prefixed with -100).
TELEGRAM_BOT_TOKENS=123456:ABC-bot-token-one,789012:DEF-bot-token-two
TELEGRAM_CHANNEL_IDS=-1001234567890,-1009876543210

# --- Supabase (Postgres + Auth) — SPEC §2, §6.3 -----------------------------
# Project URL and keys from the Supabase dashboard (Project Settings → API).
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-secret-key
# JWT secret used to issue/verify session tokens (Project Settings → API → JWT).
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
# Direct Postgres connection — used ONLY to run the SQL migrations
# (telecloud/database/migrations) via psql/Supabase CLI; the app never reads it.
# Connection string from Project Settings → Database. Optional for running the app.
DATABASE_URL=postgresql://postgres:LDnWPH5aN4WMVSUC@db.your-project-ref.supabase.co:5432/postgres

# --- Upstash Redis (rate limiting + retry queue) — SPEC §6.6 ----------------
# REST URL + token from the Upstash console.
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token

# --- Resend (verification email) — SPEC §6.15 -------------------------------
RESEND_API_KEY=re_your_resend_api_key
# From-address: a bare address or a display form like "TeleCloud <noreply@x.com>".
RESEND_FROM_EMAIL=TeleCloud <noreply@yourdomain.com>

# --- QStash (cron / cleanup callbacks) — SPEC §6.14 -------------------------
# Two signing keys so QStash key rotation never drops a request (verify against
# either). Found in the Upstash QStash console.
QSTASH_CURRENT_SIGNING_KEY=sig_your_current_signing_key
QSTASH_NEXT_SIGNING_KEY=sig_your_next_signing_key

# --- App --------------------------------------------------------------------
# Public base URL used to build verification / share links. No trailing slash.
APP_BASE_URL=https://telecloud.fly.dev
# Extra browser origins allowed by CORS (comma-separated), e.g. the Vercel
# frontend URL(s). The origin derived from APP_BASE_URL is always allowed too.
CORS_ALLOWED_ORIGINS=https://telecloud.vercel.app
# Optional: deploy environment label (development | staging | production).
APP_ENV=development
